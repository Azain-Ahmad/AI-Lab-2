        "import heapq\n",
        "\n",
        "class Node:\n",
        "    def __init__(self, vertex, cost):\n",
        "        self.vertex = vertex\n",
        "        self.cost = cost\n",
        "\n",
        "def ucs(graph, start, goal):\n",
        "    pq = []\n",
        "    heapq.heappush(pq, (0, start))  # (cost, vertex)\n",
        "\n",
        "    visited = {}\n",
        "\n",
        "    while pq:\n",
        "        cost, v = heapq.heappop(pq)\n",
        "\n",
        "        if v in visited:\n",
        "            continue\n",
        "\n",
        "        visited[v] = cost\n",
        "        print(\"Visited:\", v, \"Cost:\", cost)\n",
        "\n",
        "        if v == goal:\n",
        "            print(\"Goal reached with cost:\", cost)\n",
        "            return\n",
        "\n",
        "        for neighbor, edge_cost in graph.get(v, []):\n",
        "            if neighbor not in visited:\n",
        "                heapq.heappush(pq, (cost + edge_cost, neighbor))\n",
        "\n",
        "\n",
        "# Graph definition\n",
        "graph = {\n",
        "    \"S\": [(\"A\", 3), (\"B\", 2), (\"C\", 7)],\n",
        "    \"A\": [(\"D\", 8), (\"E\", 15), (\"G\", 15)],\n",
        "    \"B\": [(\"G\", 20)],\n",
        "    \"C\": [(\"G\", 6)],\n",
        "    \"D\": [],\n",
        "    \"E\": [],\n",
        "    \"G\": []\n",
        "}\n",
        "\n",
        "start = \"S\"\n",
        "goal = \"G\"\n",
        "\n",
        "ucs(graph, start, goal)"
      ]
